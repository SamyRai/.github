{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor"
  ],
  "labels": ["dependencies"],
  "assignees": ["mukimovd"],
  "packageRules": [
    {
      "matchDatasources": ["go"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "groupName": "all non-major go dependencies"
    }
  ]
}
