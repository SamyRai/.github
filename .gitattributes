# Set default behavior, in case people don't have core.autocrlf set.
* text=auto

# Explicitly declare text files you want to always be normalized and converted
# to native line endings on checkout.
*.go text
*.md text
*.yaml text
*.yml text
*.sh text eol=lf

# Denoting files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

# Linguist overrides (Language detection for GitHub/Gitea)
# Ignore vendor and generated directories from repo language statistics
vendor/* linguist-vendored
node_modules/* linguist-vendored
dist/* linguist-vendored
build/* linguist-vendored
*.pb.go linguist-generated=true
